# ArkDO 推送中继配置。复制为 /etc/wp-relay.env,填好后 chmod 640。
# 这个文件含密钥,切勿提交到版本库。

# ── 必填 ───────────────────────────────────────────────────────────────
# 本中继对外的 https 基址(不带结尾斜杠)。会被拼进订阅 endpoint 交给 Discourse,
# 填错推送就投不回来。漏填时中继拒绝启动。
RELAY_PUBLIC_BASE=https://push.example.com

# ── 华为 Push Kit(不配则只解密不下发,可用于先验证 Discourse→中继这一段)──
# AGC → 项目设置 → 常规 → 项目 ID
PUSHKIT_PROJECT_ID=
# AGC → 项目设置 → 服务账号密钥,下载的 JSON 放服务器上,权限建议 640 root:<运行用户>
PUSHKIT_SERVICE_ACCOUNT_FILE=/etc/wp-relay-service-account.json

# 消息分类。华为对每条 messages:send 都校验分类权益,需先在 AGC 申请并通过审核。
#   PUSHKIT_CATEGORY          私信类通知用(即时聊天)
#   PUSHKIT_CATEGORY_DEFAULT  其余通知(回复/@/点赞等)用;留空则回落到 PUSHKIT_CATEGORY
PUSHKIT_CATEGORY=IM
PUSHKIT_CATEGORY_DEFAULT=

# ── 客户端鉴权(可选但强烈建议)────────────────────────────────────────
# App 调 /subscription/* 时须带 X-ArkDO-Key 头。留空则不鉴权。
# 注意:密钥随 App 分发、可被反编译取出,它只挡扫描器和脚本化滥用,不是身份认证——
# 真正的防线是下面的限流与容量上限。生成:python3 -c "import secrets;print(secrets.token_urlsafe(32))"
RELAY_API_KEY=

# ── 限流与容量(默认值适合个人部署)──────────────────────────────────
# 单 IP 在 RELAY_RATE_WINDOW 秒内最多多少次 /subscription/* 请求;设 0 关闭限流。
RELAY_RATE_WINDOW=60
RELAY_RATE_MAX=20
# 订阅总量上限。达到后先清陈旧记录,仍满则返回 503。
RELAY_MAX_SUBS=5000
# 已停用且超过这么多天没更新的订阅记录直接丢弃;设 0 关闭清理。
RELAY_STALE_DAYS=30

# ── 日志 ───────────────────────────────────────────────────────────────
# 超过这个字节数滚存一份 .1(只留一代)。
RELAY_LOG_MAX_BYTES=2097152
# 设为 1 才把通知标题等用户内容写进日志。默认关闭——那是用户的私信/回帖内容,
# 不该长期落在磁盘上。仅排障时临时打开,查完记得关。
RELAY_LOG_CONTENT=
